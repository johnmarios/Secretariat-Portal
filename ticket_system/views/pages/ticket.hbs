<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Λεπτομέρειες Αιτήματος - Secretariat Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="../css/navbar.css" rel="stylesheet">
    <link href="../css/ticket.css" rel="stylesheet">
    <link href="../css/student-info.css" rel="stylesheet">
</head>

<body class="ticket-page">
    <!-- Navbar -->
    {{>dashboard-navbar}}

    <main class="ticket-main">
        <div class="container-fluid ticket-container">
            <!-- Header -->
            <div class="ticket-header">
                <div class="header-left">
                    <span class="ticket-id">Ticket ID: {{ticket.ticket_id}}</span>
                    <h1 class="ticket-title">{{ticket.subject}}</h1>
                </div>
                <div class="header-right">
                    <select class="status-select">
                        <option value="open" {{#eq ticket.status 'open'}}selected{{/eq}}>Ανοιχτό</option>
                        <option value="in_progress" {{#eq ticket.status 'in_progress'}}selected{{/eq}}>Σε εξέλιξη</option>
                        <option value="pending" {{#eq ticket.status 'pending'}}selected{{/eq}}>Εκκρεμές</option>
                        <option value="resolved" {{#eq ticket.status 'resolved'}}selected{{/eq}}>Επιλυμένο</option>
                        <option value="closed" {{#eq ticket.status 'closed'}}selected{{/eq}}>Κλειστό</option>
                    </select>
                    <button class="escalate-btn">Escalate to Leader</button>
                </div>
            </div>

            <!-- Main Content -->
            <div class="ticket-content">
                <!-- Left Column: Student Info Partial -->
                <aside class="student-info-sidebar">
                    <div class="student-info-card" data-student-id="{{ticket.student_id}}">
                        {{>student-info}}
                    </div>
                </aside>

                <!-- Right Column: Ticket Details -->
                <section class="ticket-details">
                    <div class="details-card">
                        <h3>Περιγραφή</h3>
                        <p>{{ticket.description}}</p>
                    </div>

                    <div class="details-card">
                        <h3>Προτεραιότητα</h3>
                        <span class="priority-badge priority-{{ticket.priority}}">{{ticket.priority}}</span>
                    </div>

                    <div class="details-card">
                        <h3>Δημιουργία</h3>
                        <p>{{formatDate ticket.created_at}}</p>
                    </div>
                </section>
            </div>
        </div>
    </main>

    <!-- Footer -->
    {{>footer}}

    <script src="../js/script.js"></script>
</body>
</html>
