{{!-- Create Ticket Page --}}
<link rel="stylesheet" href="/createTicket.css">
<div class="container create-ticket-page">
  <h1 class="page-title">Δημιουργία Αιτήματος</h1>

  <div class="grid three-col">
    <!-- Left: Student Card Partial -->
    <aside class="col left-col">
      {{>studentCard}}
    </aside>

    <!-- Middle: Ticket Form (without attachment area) -->
    <main class="col middle-col">
      <div class="card form-card">
        <h2>Το Αίτημά μου</h2>

        <form id="createTicketForm" method="post" action="/tickets/create">
          <div class="form-group">
            <label for="category">ΚΑΤΗΓΟΡΙΑ ΑΙΤΗΜΑΤΟΣ*</label>
            <select id="category" name="category" class="form-control">
              <option value="">Επιλέξτε Κατηγορία...</option>
              <option value="1">Διοικητικά</option>
              <option value="2">Βεβαιώσεις</option>
            </select>
          </div>

          <div class="form-group">
            <label for="subject">ΘΕΜΑ*</label>
            <input id="subject" name="subject" class="form-control" placeholder="Γράψτε ένα σύντομο Θέμα" />
          </div>

          <div class="form-group">
            <label for="description">ΠΕΡΙΓΡΑΦΗ ΑΙΤΗΜΑΤΟΣ*</label>
            <textarea id="description" name="description" class="form-control" rows="8" placeholder="Περιγράψτε αναλυτικά το αίτημά σας..."></textarea>
          </div>

          {{!-- note: attachment handled in right column via fileAttachment partial --}}

        </form>
      </div>
    </main>

    <!-- Right: File Attachment + Submit -->
    <aside class="col right-col">
      <div class="card attachments-card">
        <h2>Υποβολή</h2>

        {{>fileAttachment}}

        <div class="submit-wrap">
          <button id="submitTicketBtn" class="btn btn-primary btn-block">Υποβολή Αιτήματος</button>
        </div>
      </div>
    </aside>
  </div>
</div>
<script src="/fileAttachment.js"></script>
<script src="/createTicket.js"></script>
