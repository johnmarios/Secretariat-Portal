{{!-- Create Ticket Page --}}
<link rel="stylesheet" href="/createTicket.css">
<div class="container create-ticket-page">
  <h1 class="page-title">Δημιουργία Αιτήματος</h1>

  <div class="grid three-col">
    <!-- Left: Student Card Partial -->
    <aside class="col left-col">
      {{>studentCard}}
    </aside>

    <!-- Middle: Ticket Form  -->
    <main class="col middle-col">
      <div class="card form-card">
        <h2>Το Αίτημά μου</h2>

        <form id="createTicketForm" method="post" action="/tickets/create"> 
          <div class="form-group">
            <label for="category">ΚΑΤΗΓΟΡΙΑ ΑΙΤΗΜΑΤΟΣ*</label>
            <select id="category" name="category" class="form-control">
              <option value="" disabled selected>Επιλέξτε Κατηγορία...</option>

              <optgroup label="Βεβαιώσεις & Πιστοποιητικά">
                <option value="cert_enrollment">Βεβαίωση Σπουδών (Γενική Χρήση)</option>
                <option value="cert_transcript">Αναλυτική Βαθμολογία</option>
                <option value="cert_military">Πιστοποιητικό για Στρατολογική Χρήση</option>
                <option value="cert_tax">Βεβαίωση για Εφορία / Επίδομα Ενοικίου</option>
                <option value="cert_diploma_copy">Αντίγραφο Πτυχίου / Διπλώματος</option>
              </optgroup>

              <optgroup label="Ακαδημαϊκά Θέματα">
                <option value="acad_registration">Πρόβλημα με την Εγγραφή / Ανανέωση</option>
                <option value="acad_courses">Θέματα Δηλώσεων Μαθημάτων</option>
                <option value="acad_regrading">Αίτηση Αναβαθμολόγησης</option>
                <option value="acad_exam_review">Επανεξέταση Μαθήματος</option>
                <option value="acad_graduation">Αίτηση για Ορκωμοσία / Λήψη Πτυχίου</option>
              </optgroup>

              <optgroup label="Φοιτητική Κατάσταση">
                <option value="status_suspension">Αναστολή Σπουδών</option>
                <option value="status_deletion">Αίτηση Διαγραφής από το Τμήμα</option>
                <option value="status_transfer">Θέματα Μετεγγραφών</option>
                <option value="status_pass">Πρόβλημα με την Ακαδημαϊκή Ταυτότητα (Πάσο)</option>
              </optgroup>

              <optgroup label="Λοιπά">
                <option value="general_query">Γενικό Ερώτημα / Πληροφορίες</option>
                <option value="other">Άλλο (Περιγράψτε παρακάτω)</option>
              </optgroup>

            </select>
          </div>

          <div class="form-group">
            <label for="subject">ΘΕΜΑ*</label>
            <input id="subject" name="subject" class="form-control" placeholder="Γράψτε ένα σύντομο Θέμα" />
          </div>

          <div class="form-group">
            <label for="description">ΠΕΡΙΓΡΑΦΗ ΑΙΤΗΜΑΤΟΣ*</label>
            <textarea id="description" name="description" class="form-control" rows="8"
              placeholder="Περιγράψτε αναλυτικά το αίτημά σας..."></textarea>
          </div>

        </form>
      </div>
    </main>

    <!-- Right: File Attachment + Submit -->
    <aside class="col right-col">
      <div class="card attachments-card">

        {{>fileAttachment}}

        <div class="submit-wrap">
          <button id="submitTicketBtn" class="btn btn-primary btn-block">Υποβολή Αιτήματος</button>
        </div>
      </div>
    </aside>
  </div>
</div>
<script src="/fileAttachment.js"></script>
<script src="/createTicket.js"></script>