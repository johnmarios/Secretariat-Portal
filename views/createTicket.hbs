{{!-- Create Ticket Page --}}
<link rel="stylesheet" href="/css/pages/createTicket.css">
<div class="container create-ticket-page">
  <h1 class="page-title">Δημιουργία Αιτήματος</h1>


  <div class="grid three-col">
    <!-- Left: Student Card Partial -->
    <aside class="col left-col">
      {{>studentCard}}
    </aside>

    <!-- Middle: Ticket Form  -->
    <main class="col middle-col">
      <div class="card form-card">
        <h2>Το Αίτημά μου</h2>

        <form id="createTicketForm" method="post" enctype="multipart/form-data" action="/create-ticket/{{studentId}}">
          <input type="hidden" name="student_id" value="{{studentId}}">
          <div class="form-group">
            <label for="category">ΚΑΤΗΓΟΡΙΑ ΑΙΤΗΜΑΤΟΣ*</label>
            <select id="category" name="category_id" class="form-control" required>
              <option value="" selected disabled>-- Επιλέξτε κατηγορία --</option>
              {{#each groupedCategories}}
              <optgroup label="{{this.themeName}}">
                {{#each this.options}}
                <option value="{{this.id}}">{{this.name}}</option>
                {{/each}}
              </optgroup>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="subject">ΘΕΜΑ*</label>
            <input id="subject" name="subject" class="form-control" placeholder="Γράψτε ένα σύντομο Θέμα" />
          </div>

          <div class="form-group">
            <label for="description">ΠΕΡΙΓΡΑΦΗ ΑΙΤΗΜΑΤΟΣ*</label>
            <textarea id="description" name="description" class="form-control" rows="8"
              placeholder="Περιγράψτε αναλυτικά το αίτημά σας..."></textarea>
          </div>

      </div>
    </main>

    <!-- Right: File Attachment + Submit -->
    <aside class="col right-col">
      <div class="card attachments-card">

        {{>fileAttachment}}

        <div class="submit-wrap">
          <button id="submitTicketBtn" type="submit" class="btn btn-primary btn-block">Υποβολή Αιτήματος</button>
        </div>
      </div>
    </aside>
    </form>
  </div>
</div>
<script src="/js/partials/fileAttachment.js" defer></script>
<script src="/js/pages/createTicket.js" defer></script>