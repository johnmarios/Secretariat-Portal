<div class="student-search-mode" id="studentSearchMode">
	<h3 class="student-card-title">Στοιχεία Φοιτητή</h3>

	<label class="student-search-label" for="studentSearchInput">Αναζήτηση φοιτητή</label>
	<div class="student-search-field">
		<input
			id="studentSearchInput"
			type="text"
			class="student-search-input"
			placeholder="🔍 Αναζήτηση με ΑΜ ή Επώνυμο..."
			autocomplete="off"
			aria-autocomplete="list"
			aria-controls="studentAutocompleteList"
		>
		<ul class="student-autocomplete" id="studentAutocompleteList" hidden></ul>
	</div>

	<p class="student-search-hint">Επιλέξτε φοιτητή για να συμπληρωθούν αυτόματα τα στοιχεία του.</p>

	<input type="hidden" name="for_student_id" id="selectedStudentId" form="createTicketForm">
</div>

<div class="selected-student-card" id="selectedStudentCard" hidden>
	<button type="button" class="selected-student-card__change" id="changeStudentButton">Αλλαγή</button>

	<img class="student-avatar" src="/images/avatar-person.svg" alt="Student Avatar">

	<p class="student-name" id="selectedStudentName"></p>

	<div class="info-row">
		<span class="label">ΑΜ:</span>
		<span class="value" id="selectedStudentAm"></span>
	</div>

	<div class="info-row">
		<span class="label">ΤΜΗΜΑ:</span>
		<span class="value" id="selectedStudentDepartment"></span>
	</div>

	<div class="info-row">
		<span class="label">EMAIL:</span>
		<span class="value" id="selectedStudentEmail"></span>
	</div>

	<div class="info-row">
		<span class="label">ΕΤΟΣ ΣΠΟΥΔΩΝ:</span>
		<span class="value" id="selectedStudentStudyYear"></span>
	</div>
</div>
