<div class="modal-overlay" id="ticketModal">
    <div class="modal-nav">
      <button class="close-btn" id="closeModalBtn"></button>
    </div>
    <div class="modal-content">
      
      <div class="modal-col col-white">
        
        <div class="info-group">
          <span class="label">ID:</span>
          <span class="value" id="modal-id">-</span>
        </div>
        <div class="info-group">
          <span class="label">Ημερομηνία Υποβολής:</span>
          <span class="value" id="modal-date">-</span>
        </div>
        <div class="info-group">
          <span class="label">Κατηγορία:</span>
          <span class="value fw-bold" id="modal-category">-</span>
        </div>
        <div class="info-group">
          <span class="label">Θέμα:</span>
          <span class="value" id="modal-subject">-</span>
        </div>
        <div class="info-group">
          <span class="label">Επισυναπτόμενα αρχεία:</span>
          <span class="value" id="modal-attachments">-</span>
        </div>
      </div>

      <div class="modal-col col-gray">
        <div class="info-group">
          <span class="label">Ονοματεπώνυμο:</span>
          <span class="value" id="modal-student">-</span>
        </div>
        <div class="info-group">
          <span class="label">Α.Μ.:</span>
          <span class="value" id="modal-am">-</span>
        </div>
        <div class="info-group">
          <span class="label">Email:</span>
          <span class="value" id="modal-email">-</span>
        </div>
        <div class="info-group">
          <span class="label">Σχολή / Τμήμα:</span>
          <span class="value">Μηχανικών Η/Υ και Πληροφορικής</span> </div>
        <div class="info-group">
          <span class="label">Έτος Σπουδών:</span>
          <span class="value study-year" id="modal-year">-</span>
        </div>
      </div>

      <div class="modal-col col-white">
      
        <div class="info-group">
          <span class="label">Περιγραφή αιτήματος:</span>
          <div class="description-box" id="modal-description" style="padding: 10px; overflow-y: auto;">-</div>
        </div>
        
        <form id="modalAssignForm" method="POST" action="" style="display: none; margin-top: auto; padding-top: 10px;">
           <button type="submit" class="btn btn-primary w-100" style="padding: 9px; font-weight: bold;">
            Αναλαμβάνω
        </form>
      </div>
      
      <div class="modal-col col-gray" id="modal-internal-col" style="display: none; border-left: 1px solid #eee; background-color: #fff9e6;">
        <div class="info-group">
          <span class="label text-warning fw-bold">Σχόλιο Γραμματείας:</span>
          <div class="description-box" id="modal-internal-desc" style="padding: 10px; overflow-y: auto; background-color: #fff; border-color: #ffd700;">-</div>
        </div>
        
        <div style="display: flex; gap: 10px; margin-top: auto; padding-top: 20px;">
            <form id="modalAcceptEscalatedForm" method="POST" style="flex: 1;">
               <button type="submit" class="btn btn-success w-100" style="padding: 12px; font-weight: bold;">
                  Ανάληψη
               </button>
            </form>
            <form id="modalRejectEscalatedForm" method="POST" style="flex: 1;">
               <button type="submit" class="btn btn-danger w-100" style="padding: 12px; font-weight: bold;">
                  Απόρριψη
               </button>
            </form>
        </div>
      </div>

    </div>
</div>