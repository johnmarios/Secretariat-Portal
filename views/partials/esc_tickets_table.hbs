<div class="table-responsive">
    <table class="requests-table table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>ΑΜ</th>
                <th>Κατηγορία</th>
                <th>Θέμα</th>
                <th>Ημερομηνία Υποβολής</th>
                <th>Προωθήθηκε από</th>
            </tr>
        </thead>
        <tbody>
            {{#each tickets}}
            <tr data-ticket-id="{{this.id}}" data-modal-type="escalated">
                <td>{{this.id}}</td>
                <td>{{this.am}}</td>
                <td>{{this.category}}</td>
                <td>{{this.subject}}</td>
                <td>{{this.submittedAt}}</td>
                {{!-- <td>
                    <span class="status {{this.statusClass}}">
                        <span class="dot"></span> {{this.status}}
                    </span>
                </td> --}}
                <td>
                    {{#if this.assignedSecretaryName}}
                        <span class="text-muted"><i class="fas fa-user-check me-1"></i>{{this.assignedSecretaryName}}</span>
                    {{else}}
                        <span class="text-danger italic">-</span>
                    {{/if}}
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>