{{> auth-navbar}}

<main class="login-main">
  <article class="login-card">
    <div class="card-header">
      <h3>Συνδεθείτε στον λογαριασμό σας</h3>
    </div>

    <form action="/api/login" method="POST" class="login-body">
      
      <input type="email" name="email" placeholder="Email" required>
      <input type="password" name="password" placeholder="Password" required>

      <a href="#" class="small-link">Forgot password?</a>

      <button type="submit" class="submit-btn login-btn">Σύνδεση</button>

      <p class="small-link">Don't have an account yet? <a href="#">Sign up.</a></p>
    </form>
  </article>
</main>